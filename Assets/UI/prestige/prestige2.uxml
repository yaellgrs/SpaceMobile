            <engine:VisualElement style="flex-grow: 1; right: -5%; height: 51px; width: 53px; position: absolute; top: 5%; background-image: url(&quot;project://database/Assets/art/g%C3%A9n%C3%A9ral/star_Particule.png?fileID=2800000&amp;guid=99be6ca9f78c0104e9af4b058fffd2dd&amp;type=3#star_Particule&quot;);" />
