  - m_Id: 1339554738176
    m_Localized: Omega-Wahrscheinlichkeit
    m_Metadata:
      m_Items: []
  - m_Id: 1392893702144
    m_Localized: Multipliziere den Gewinn an Sternpartikeln mit dem Prestige.
    m_Metadata:
      m_Items: []
  - m_Id: 2683770449920
    m_Localized: "Reduziere die Meteore, die zerst\xF6rt werden m\xFCssen, um zur
      n\xE4chsten Stufe zu gelangen."
    m_Metadata:
      m_Items: []
  - m_Id: 2724232900608
    m_Localized: Reduziere die Arbeitszeit aller Maschinen.
    m_Metadata:
      m_Items: []
  - m_Id: 2793229201408
    m_Localized: Reduziere die notwendigen Preise, um alle Verbesserungen hochzustufen.
    m_Metadata:
      m_Items: []
  - m_Id: 2816323039232
    m_Localized: Multipliziere den XP-Gewinn.
    m_Metadata:
      m_Items: []
  - m_Id: 2862972088320
    m_Localized: Multipliziere den verursachten Schaden an den Meteoriten.
    m_Metadata:
      m_Items: []
  - m_Id: 2891522715648
    m_Localized: "Erh\xF6he die Wahrscheinlichkeit, einen Omega-Meteoriten zu finden."
    m_Metadata:
      m_Items: []
  - m_Id: 5187254038528
    m_Localized: "Todo est\xE1 comprado."
    m_Metadata:
      m_Items: []
  - m_Id: 10988911800320
    m_Localized: Salto de nivel
    m_Metadata:
      m_Items: []
  - m_Id: 11328818196480
    m_Localized: "Gibt dir eine Chance, ein Level zu \xFCberspringen."
    m_Metadata:
      m_Items: []
  - m_Id: 653433680900096
    m_Localized: Du schaltest die automatische Eisenmaschine frei
    m_Metadata:
      m_Items: []
  - m_Id: 653523736801280
    m_Localized: Du schaltest die automatische Uranmaschine frei
    m_Metadata:
      m_Items: []
  - m_Id: 653525301276672
    m_Localized: "+25\u202F% Belohnung f\xFCr alle Maschinen"
    m_Metadata:
      m_Items: []
  - m_Id: 653525901062144
    m_Localized: "+25\u202F% mehr Sterne beim Prestigen"
    m_Metadata:
      m_Items: []
  - m_Id: 653526475681792
    m_Localized: "+25\u202F% permanenter Schaden an allen Raumschiffen"
    m_Metadata:
      m_Items: []
  - m_Id: 653527075467264
    m_Localized: Prestige wurde freigeschaltet
    m_Metadata:
      m_Items: []
  - m_Id: 653677948776448
    m_Localized: Uran wurde freigeschaltet, du schaltest das Verlangsamungsfeld,
      automatischen Schuss und Uran-Upgrades frei
    m_Metadata:
      m_Items: []
  - m_Id: 653724945952768
    m_Localized: "+0,5\u202F% Chance, einen Diamant-Meteoriten zu finden"
    m_Metadata:
      m_Items: []
  - m_Id: 653771494338560
    m_Localized: "Neues Raumschiff verf\xFCgbar!"
    m_Metadata:
      m_Items: []
  - m_Id: 653797469663232
    m_Localized: Du kannst das Spiel jetzt beschleunigen
    m_Metadata:
      m_Items: []
  - m_Id: 653817535213568
    m_Localized: "+15\u202F% Produktion im Offline-Modus"
    m_Metadata:
      m_Items: []
  - m_Id: 653847943917568
    m_Localized: "+5\u202F% Chance auf kritischen Treffer"
    m_Metadata:
      m_Items: []
  - m_Id: 653884488888320
    m_Localized: "-2\u202Fs zur Regeneration deines Schildes"
    m_Metadata:
      m_Items: []
  - m_Id: 68714996010160128
    m_Localized: "Schalte die Rakete frei; sie erm\xF6glicht es, in kritischen Momenten
      gro\xDFen Schaden zu verursachen."
