  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: UI_Quests_de
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: de
  m_SharedData: {fileID: 11400000, guid: f08e391c545fdab4d9c91542a36284fb, type: 2}
  m_Metadata:
    m_Items:
    - rid: 9040802075139375378
  m_TableData:
  - m_Id: 5438910464
    m_Localized: Es gibt zu viele Meteoriten im Weltraum, bitte helfen Sie mir !
    m_Metadata:
      m_Items: []
  - m_Id: 285480005632
    m_Localized: 'Reinigen Sie den Weltraum von Meteoren :'
    m_Metadata:
      m_Items: []
  - m_Id: 85868537655296
    m_Localized: Uns geht das Eisen aus. Zielt auf Eisen-Meteoriten, um mehr zu sammeln!
      Verbessert die Schmiede, um mehr aus jedem Einschlag herauszuholen!
    m_Metadata:
      m_Items: []
  - m_Id: 86366347014144
    m_Localized: "\rVerdiene Eisen, indem du Eisenmeteoriten zerst\xF6rst :"
    m_Metadata:
      m_Items: []
  - m_Id: 336272101945344
    m_Localized: 'Verbessere dein Schiff mit Eisen :'
    m_Metadata:
      m_Items: []
  - m_Id: 336869618298880
    m_Localized: "Um l\xE4nger zu \xFCberleben, muss unser Schiff verst\xE4rkt werden!
      Verwende dein Eisen, um es aufzur\xFCsten."
    m_Metadata:
      m_Items: []
  - m_Id: 466121177116672
    m_Localized: "Obt\xE9n part\xEDculas estelares con un solo prestigio :"
    m_Metadata:
      m_Items: []
  - m_Id: 466124553531392
    m_Localized: "Jetzt, wo wir st\xE4rker sind, ist es Zeit zu handeln. Zerst\xF6re
      Meteoriten!"
    m_Metadata:
      m_Items: []
  - m_Id: 470882718789632
    m_Localized: "Du hast gro\xDFe Fortschritte gemacht, aber jetzt ist es Zeit,
      neu zu starten\u2026 nur besser!\nMach einen Prestige, um noch st\xE4rker zur\xFCckzukommen."
    m_Metadata:
      m_Items: []
  - m_Id: 738363026911232
    m_Localized: Jetzt ist es an der Zeit, die Macht des Urans zu nutzen. Aber zuerst
      musst du etwas Uran sammeln! Denk daran, deine Uran-Schmiede zu verbessern,
      um viel mehr aus Uran-Meteoriten zu gewinnen.
    m_Metadata:
      m_Items: []
  - m_Id: 739707456532480
    m_Localized: "Verdiene Uran, indem du Uran-Meteoriten zerst\xF6rst:"
    m_Metadata:
      m_Items: []
  - m_Id: 739583590346752
    m_Localized: Gut gemacht! Jetzt verbessere das Raumschiff mit Uran!
    m_Metadata:
      m_Items: []
  - m_Id: 739708047929344
    m_Localized: 'Verbessere das Raumschiff mit Uran:'
    m_Metadata:
      m_Items: []
  - m_Id: 857070512320512
    m_Localized: "Gl\xFCckwunsch! Du hast alle Quests abgeschlossen! Jetzt ist es
      Zeit, das Raumschiff zu wechseln!"
    m_Metadata:
      m_Items: []
  - m_Id: 1245777727795200
    m_Localized: "Um die Ertr\xE4ge von Eisen- und Uranmeteroiten voll auszusch\xF6pfen,
      brauchst du vor allem gut ausgestattete Schmieden! Verbessere alle deine Generatoren
      so weit wie m\xF6glich."
    m_Metadata:
      m_Items: []
  - m_Id: 1245862343684096
    m_Localized: "Ein Eisengenerator reicht nicht mehr aus, um weiterzukommen. Wie
      w\xE4re es, wenn du sparst, um deine Produktion zu verdoppeln?"
    m_Metadata:
      m_Items: []
  - m_Id: 1245862968635392
    m_Localized: "Wie w\xE4re es mit einer kleinen Herausforderung? Versuche, die
      ersten 20 Meteorwellen in weniger als 5 Minuten zu schaffen! Z\xF6gere nicht,
      die Meteor-Geschwindigkeit auf x2 zu stellen."
    m_Metadata:
      m_Items: []
  - m_Id: 1246248500670464
    m_Localized: 'Verbessere die Generatoren in deinen Schmieden:'
    m_Metadata:
      m_Items: []
  - m_Id: 1246249826070528
    m_Localized: 'Kauf einen zweiten Eisengenerator:'
    m_Metadata:
      m_Items: []
  - m_Id: 1246252795637760
    m_Localized: "Beende {stage} m\xF6gliche Wellen in 5 Minuten:"
    m_Metadata:
      m_Items:
      - rid: 9040802075139375378
  references:
    version: 2
