  m_TableData:
  - m_Id: 167171166208
    m_Localized: Eisenmeteorit
    m_Metadata:
      m_Items: []
  - m_Id: 292106899456
    m_Localized: Uranmeteorit
    m_Metadata:
      m_Items: []
  - m_Id: 306208149504
    m_Localized: Rakete
    m_Metadata:
      m_Items: []
  - m_Id: 6869958365184
    m_Localized: "Du entdeckst den Eisenmeteoriten!\n\nDer Eisenmeteorit gibt Eisen
      basierend auf der Schmiede-Belohnung, ist jedoch relativ selten.\n\nSobald
      er zerst\xF6rt ist, kannst du das Eisen im Weltraum einsammeln."
    m_Metadata:
      m_Items: []
  - m_Id: 6872076488704
    m_Localized: "Du entdeckst den Uranmeteoriten!\n\nDer Uranmeteorit gibt Uran
      basierend auf der Schmiede-Belohnung, ist jedoch relativ selten.\n\nSobald
      er zerst\xF6rt ist, kannst du das Uran im Weltraum einsammeln."
    m_Metadata:
      m_Items: []
  - m_Id: 6876887355392
    m_Localized: "Schalte die Rakete frei!\n\nSie zielt automatisch auf den st\xE4rksten
      Meteor und verursacht enormen Schaden.\n\nWenn eine Rakete einen spaltenden
      Meteor zerst\xF6rt, bevor er sich teilt, erscheinen seine Fragmente nicht."
    m_Metadata:
      m_Items: []
  - m_Id: 52206597148672
    m_Localized: Diamant-Meteor
    m_Metadata:
      m_Items: []
  - m_Id: 52211282186240
    m_Localized: Splitter-Meteor
    m_Metadata:
      m_Items: []
  - m_Id: 52215937863680
    m_Localized: "Verst\xE4rkter Meteor"
    m_Metadata:
      m_Items: []
  - m_Id: 52837399498752
    m_Localized: 'Du entdeckst den Diamant-Meteor!


      Der Diamant-Meteor gibt
      1 Diamanten, ist aber extrem selten.


      Er ist kleiner, schneller und
      hat mehr Lebenspunkte, verursacht jedoch keinen Schaden am Raumschiff.'
    m_Metadata:
      m_Items: []
  - m_Id: 52841463779328
    m_Localized: "Du entdeckst den Splitter-Meteor!\n\nWenn der Splitter-Meteor zerst\xF6rt
      wird, spaltet er sich in zwei kleinere Meteore.\n\nDie kleineren Meteore geben
      keine EP."
    m_Metadata:
      m_Items: []
  - m_Id: 52843292495872
    m_Localized: "Du entdeckst den verst\xE4rkten Meteor!\n\nDer verst\xE4rkte Meteor
      hat mehr Lebenspunkte, ist aber langsamer."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
